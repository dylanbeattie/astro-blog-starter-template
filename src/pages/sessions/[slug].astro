---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { client, imageUrl, portableTextToHtml, sanitizeSlug } from '../../lib/sanity';

export async function getStaticPaths() {
	const sessions = await client.fetch(
		`*[_type == "slot" && defined(slug.current)] {
			title, slug, slotType, level,
			"description": description.en,
			"article": article.en,
			speakers[]->{ _id, firstName, lastName, slug, portrait, "position": position.en, company },
			topics[]->{ title, slug },
			schedule[]{
				fromDate, toDate, duration,
				"venue": location.venue->title,
				"room": location.room->title,
				"isRemote": location.isRemote
			}
		}`
	);
	return sessions.map((session: any) => ({
		params: { slug: sanitizeSlug(session.slug.current) },
		props: { session },
	}));
}

const { session } = Astro.props;
const articleHtml = portableTextToHtml(session.article);

function formatDate(dt: string): string {
	return new Date(dt).toLocaleDateString('en-GB', { dateStyle: 'medium' });
}
function formatTime(dt: string): string {
	return new Date(dt).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={session.title}
			description={session.description ?? session.title}
		/>
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 1rem 2rem;
			}
			.back {
				display: inline-block;
				margin-bottom: 1.5rem;
				font-size: 0.9rem;
			}
			h1 {
				margin-bottom: 0.5rem;
			}
			.badges {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 1.25rem;
			}
			.badge {
				display: inline-block;
				background: #eee;
				border-radius: 4px;
				padding: 0.15rem 0.5rem;
				font-size: 0.8rem;
				color: #555;
				text-transform: capitalize;
			}
			.topics {
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
				margin-bottom: 1.5rem;
			}
			.topic {
				background: #f0f0f0;
				border-radius: 4px;
				padding: 0.2rem 0.6rem;
				font-size: 0.85rem;
				text-decoration: none;
				color: inherit;
			}
			.topic:hover {
				background: #ddd;
			}
			.description {
				font-size: 1.05rem;
				line-height: 1.75;
				margin-bottom: 2rem;
				color: #444;
			}
			.speakers {
				display: flex;
				gap: 1.25rem;
				flex-wrap: wrap;
				margin: 1.5rem 0 2rem;
			}
			.speaker-card {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				text-decoration: none;
				color: inherit;
			}
			.speaker-card img,
			.speaker-card .placeholder {
				width: 56px;
				height: 56px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.speaker-card .placeholder {
				background: #e8e8e8;
				display: flex;
				align-items: center;
				justify-content: center;
				color: #999;
				font-size: 1.1rem;
			}
			.speaker-card:hover strong {
				text-decoration: underline;
			}
			.speaker-meta {
				font-size: 0.82rem;
				color: #666;
			}
			.article {
				line-height: 1.75;
			}
			.article p {
				margin: 0 0 1rem;
			}
			.schedule {
				margin-top: 2.5rem;
			}
			.schedule table {
				border-collapse: collapse;
				width: 100%;
				font-size: 0.9rem;
			}
			.schedule th,
			.schedule td {
				padding: 0.5rem 0.75rem;
				border: 1px solid #eee;
				text-align: left;
			}
			.schedule th {
				background: #f5f5f5;
				font-weight: 600;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a class="back" href="/sessions/">← All sessions</a>
			<h1>{session.title}</h1>

			<div class="badges">
				<span class="badge">{session.slotType}</span>
				{session.level && <span class="badge">Level {session.level}</span>}
			</div>

			{session.topics?.length > 0 && (
				<div class="topics">
					{session.topics.map((t: any) => (
						<span class="topic">{t.title}</span>
					))}
				</div>
			)}

			{session.description && (
				<p class="description">{session.description}</p>
			)}

			{session.speakers?.length > 0 && (
				<div class="speakers">
					{session.speakers.filter((sp: any) => sp?.slug?.current).map((sp: any) => {
						const spUrl = imageUrl(sp.portrait, { w: 112, h: 112, fit: 'crop' });
						const spName = `${sp.firstName} ${sp.lastName}`;
						return (
							<a class="speaker-card" href={`/speakers/${sp.slug.current}/`}>
								{spUrl
									? <img src={spUrl} alt={spName} width={56} height={56} />
									: <span class="placeholder">{sp.firstName?.[0]}{sp.lastName?.[0]}</span>
								}
								<div>
									<strong>{spName}</strong>
									{sp.position && (
										<div class="speaker-meta">{sp.position}</div>
									)}
									{sp.company?.name && !sp.position && (
										<div class="speaker-meta">{sp.company.name}</div>
									)}
								</div>
							</a>
						);
					})}
				</div>
			)}

			{articleHtml && <div class="article" set:html={articleHtml} />}

			{session.schedule?.length > 0 && (
				<div class="schedule">
					<h2>Schedule</h2>
					<table>
						<thead>
							<tr>
								<th>Date</th>
								<th>Time</th>
								<th>Duration</th>
								<th>Location</th>
							</tr>
						</thead>
						<tbody>
							{session.schedule.map((ev: any) => (
								<tr>
									<td>{ev.fromDate ? formatDate(ev.fromDate) : '—'}</td>
									<td>
										{ev.fromDate && ev.toDate
											? `${formatTime(ev.fromDate)} – ${formatTime(ev.toDate)}`
											: '—'
										}
									</td>
									<td>{ev.duration ?? '—'}</td>
									<td>
										{ev.isRemote
											? 'Remote'
											: [ev.room, ev.venue].filter(Boolean).join(' · ') || '—'
										}
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
