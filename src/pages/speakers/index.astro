---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { client, imageUrl } from '../../lib/sanity';
import { SITE_TITLE } from '../../consts';

const speakers = await client.fetch(
	`*[_type == "speaker"] | order(lastName asc) {
		_id, firstName, lastName, slug, company, portrait
	}`
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Speakers — ${SITE_TITLE}`} description="Conference speakers" />
		<style>
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 1rem 2rem;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
				gap: 1.5rem;
				margin-top: 2rem;
			}
			.card a {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-decoration: none;
				text-align: center;
				color: inherit;
			}
			.card img,
			.card .placeholder {
				width: 120px;
				height: 120px;
				border-radius: 50%;
				object-fit: cover;
				margin-bottom: 0.75rem;
			}
			.card .placeholder {
				background: #e8e8e8;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2rem;
				color: #999;
			}
			.card h3 {
				margin: 0;
				font-size: 1rem;
				line-height: 1.3;
			}
			.card p {
				margin: 0.25rem 0 0;
				font-size: 0.8rem;
				color: #666;
			}
			.card a:hover h3 {
				text-decoration: underline;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Speakers</h1>
			<div class="grid">
				{speakers.filter((s: any) => s?.slug?.current).map((speaker: any) => {
					const url = imageUrl(speaker.portrait, { w: 240, h: 240, fit: 'crop' });
					const name = `${speaker.firstName} ${speaker.lastName}`;
					return (
						<div class="card">
							<a href={`/speakers/${speaker.slug.current}/`}>
								{url
									? <img src={url} alt={name} width={120} height={120} />
									: <span class="placeholder">{speaker.firstName?.[0]}{speaker.lastName?.[0]}</span>
								}
								<h3>{name}</h3>
								{speaker.company?.name && <p>{speaker.company.name}</p>}
							</a>
						</div>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>
